# Copy to .env (or let azure/setup_workspace.sh generate it).
# When AZURE_ML_TRACKING_URI is empty the pipeline falls back to local SQLite.
AZURE_ML_TRACKING_URI=
AZURE_SUBSCRIPTION_ID=
AZURE_LOCATION=swedencentral
AZURE_RESOURCE_GROUP=rg-mlops-predmaint
AZURE_WORKSPACE=mlw-predmaint
EXPERIMENT_NAME=predictive-maintenance
REGISTERED_MODEL_NAME=PredictiveMaintenanceModel
ENDPOINT_NAME=predmaint-endpoint
INSTANCE_TYPE=Standard_DS2_v2
# Filled in automatically after deployment:
SCORING_URI=
SCORING_KEY=
